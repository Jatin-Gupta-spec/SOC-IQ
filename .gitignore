```gitignore
# ==========================================================
# SOC-IQ - .gitignore
# ==========================================================

# ----------------------------------------------------------
# Python bytecode
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------
# Environment variables
# ----------------------------------------------------------
.env

# ----------------------------------------------------------
# Pytest
# ----------------------------------------------------------
.pytest_cache/

# ----------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------
# Operating System
# ----------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------
# Generated Reports
# ----------------------------------------------------------
output/

# ----------------------------------------------------------
# SQLite Database
# ----------------------------------------------------------
database/
*.db
*.db-journal
*.sqlite
*.sqlite3

# ----------------------------------------------------------
# Coverage Reports
# ----------------------------------------------------------
.coverage
htmlcov/
coverage.xml

# ----------------------------------------------------------
# Type Checking
# ----------------------------------------------------------
.mypy_cache/
.pytype/

# ----------------------------------------------------------
# Linting
# ----------------------------------------------------------
.ruff_cache/

# ----------------------------------------------------------
# Packaging
# ----------------------------------------------------------
build/
dist/
*.egg-info/

# ----------------------------------------------------------
# Jupyter
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
```
